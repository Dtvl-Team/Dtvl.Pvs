{
  "compileOnSave": true,
  "compilerOptions": {
    "noImplicitAny": true,
    "noEmitOnError": true,
    "declaration": false, // NOTE: true = export type
    "removeComments": false,
    "sourceMap": true,
    "target": "ESNext",
    "module": "ESNext",
    "moduleResolution": "Node"
  },
  "exclude": [
    "node_modules"
  ],
  "charset": "utf8"
}